# Database
# For production, use connection pooling to avoid max connections errors
# Example with Supabase: postgresql://user:password@host:6543/db?pgbouncer=true
# Example with Neon: Add ?connection_limit=1 to the connection string
DATABASE_URL="postgresql://user:password@localhost:5432/seerah"

# Direct (non-pooled) connection required by Prisma for migrations.
# Same host/port as DATABASE_URL but without a connection pooler.
# Most providers give you both URLs in the dashboard.
DIRECT_URL="postgresql://user:password@localhost:5432/seerah"

# Stripe keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional. Only set this if STRIPE_SECRET_KEY is a Stripe restricted key
# (rk_live_.../rk_test_...) for which live/test-mode detection via key prefix
# is not reliable in this deployment. When set, this takes precedence over
# key-prefix sniffing in lib/stripe.ts (isStripeLiveMode). Leave unset for a
# normal sk_live_/sk_test_ or rk_live_/rk_test_ key — both prefixes are
# already detected automatically.
# STRIPE_LIVE_MODE="true"

# ── Stripe Price IDs ─────────────────────────────────────────────────────────
# Each price_xxx ID comes from the Stripe Dashboard → Products → (product) → Prices.
# Use test-mode price IDs in development, live-mode IDs in production.

# Individual: $4.99/month recurring (new price for future customers)
# Existing $9/month subscribers are unaffected — their subscriptions are anchored
# to their original price ID in Stripe and will not be changed by updating this value.
STRIPE_PRICE_INDIVIDUAL_MONTHLY="price_1TiHMgICehG6x31hPf2gD5K4"

# Individual: $79 lifetime (one-time payment)
STRIPE_PRICE_INDIVIDUAL_LIFETIME="price_1TQjHTICehG6x31h0lkHUZPm"

# Family: $9.99/month recurring (new price for future customers)
STRIPE_PRICE_FAMILY_MONTHLY="price_1TiHMyICehG6x31hC3COn3IC"

# Family: $149 lifetime (one-time payment)
STRIPE_PRICE_FAMILY_LIFETIME="price_1Tc9QCICehG6x31hScC8aFAU"

# Legacy aliases (kept for backward compatibility — prefer the STRIPE_PRICE_* names above)
STRIPE_MONTHLY_PRICE_ID="price_1TiHMgICehG6x31hPf2gD5K4"
STRIPE_FAMILY_MONTHLY_PRICE_ID="price_1TiHMyICehG6x31hC3COn3IC"
STRIPE_FAMILY_LIFETIME_PRICE_ID="price_1Tc9QCICehG6x31hScC8aFAU"

# App URL (the public-facing Seerah app domain — used in emails, verification links, redirects)
# Set this to the deployed domain in production
NEXT_PUBLIC_APP_URL=https://themuslimman.com

# Email notifications (Resend)
RESEND_API_KEY="your_resend_api_key_here"
EMAIL_FROM="TheMuslimMan <noreply@themuslimman.com>"
ADMIN_EMAIL="themuslimman77@gmail.com"
# Support/contact form recipient email
SUPPORT_EMAIL="themuslimman77@gmail.com"

# Cron job authentication — must match Authorization: Bearer <secret> header
# Generate with: openssl rand -base64 32
# Set the same value in your Vercel cron config (vercel.json or dashboard)
CRON_SECRET="change-me-to-a-strong-random-secret"

# MailerSend (backup)
# MAILERSEND_API_KEY="mlsn...."

# AWS S3 / Cloudflare R2 (for content uploads)
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET="..."
R2_PUBLIC_URL="..."
USE_R2="true"

# Private promo codes (JSON, server-side only — never expose in client bundles)
# Format: {"CODE":{"type":"percent|fixed|absolute","value":N,"label":"..."}}
# Example: {"AMS49":{"type":"absolute","value":4900,"label":"community discount"},"FAMILY":{"type":"absolute","value":0,"label":"family access"}}
# PROMO_CODES=

# Influencer stats pages — one secret key per creator (keeps each page isolated)
# Share only each creator's own URL: https://themuslimman.com/korra/stats?key=KORRA_KEY
# Generate strong random values: openssl rand -base64 32
KORRA_STATS_KEY="change-me-to-a-strong-random-secret"
ITACHI_STATS_KEY="change-me-to-a-strong-random-secret"
DEENRESPONDS_STATS_KEY="change-me-to-a-strong-random-secret"
ORTHODOX_STATS_KEY="change-me-to-a-strong-random-secret"
BROWNIESAADI_STATS_KEY="change-me-to-a-strong-random-secret"

# CAN-SPAM §5(a)(5) physical mailing address shown in all email footers.
# Must be a real, valid postal address before sending live marketing emails.
EMAIL_PHYSICAL_ADDRESS="TheMuslimMan · PO Box 1234 · New York, NY 10001 · USA"
