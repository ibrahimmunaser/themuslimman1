# Database
# For production, use connection pooling to avoid max connections errors
# Example with Supabase: postgresql://user:password@host:6543/db?pgbouncer=true
# Example with Neon: Add ?connection_limit=1 to the connection string
DATABASE_URL="postgresql://user:password@localhost:5432/seerah"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Monthly subscription: create a recurring $9/month Price in Stripe Dashboard, copy its price_xxx ID here
STRIPE_MONTHLY_PRICE_ID="price_..."

# Family Access — lifetime one-time payment ($199)
STRIPE_FAMILY_LIFETIME_PRICE_ID="price_1Tc9QCICehG6x31hScC8aFAU"

# Family Access — monthly subscription ($19/month)
STRIPE_FAMILY_MONTHLY_PRICE_ID="price_1Tc9MkICehG6x31hl4MRyda3"

# App URL (the public-facing Seerah app domain — used in emails, verification links, redirects)
# Set this to the deployed domain in production
NEXT_PUBLIC_APP_URL=https://themuslimman.com

# Email notifications (Resend)
RESEND_API_KEY="your_resend_api_key_here"
EMAIL_FROM="TheMuslimMan <noreply@themuslimman.com>"
ADMIN_EMAIL="themuslimman77@gmail.com"

# MailerSend (backup)
# MAILERSEND_API_KEY="mlsn...."

# AWS S3 / Cloudflare R2 (for content uploads)
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET="..."
R2_PUBLIC_URL="..."
USE_R2="true"

# Private promo codes (JSON, server-side only — never expose in client bundles)
# Format: {"CODE":{"type":"percent|fixed|absolute","value":N,"label":"..."}}
# Example: {"AMS49":{"type":"absolute","value":4900,"label":"community discount"},"FAMILY":{"type":"absolute","value":0,"label":"family access"}}
# PROMO_CODES=

# Influencer stats pages — one secret key per creator (keeps each page isolated)
# Share only each creator's own URL: https://themuslimman.com/korra/stats?key=KORRA_KEY
# Generate strong random values: openssl rand -base64 32
KORRA_STATS_KEY="change-me-to-a-strong-random-secret"
ITACHI_STATS_KEY="change-me-to-a-strong-random-secret"
DEENRESPONDS_STATS_KEY="change-me-to-a-strong-random-secret"
ORTHODOX_STATS_KEY="change-me-to-a-strong-random-secret"
