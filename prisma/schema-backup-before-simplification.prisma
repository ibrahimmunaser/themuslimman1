// Seerah LMS — Prisma schema
//
// Database: Supabase PostgreSQL (session pooler, aws-1-us-west-2)
//
// Design notes:
// - Enums are represented as string constants validated at the application boundary via Zod.
// - Soft deletes are avoided; use status columns or archive flags where needed.
//
// Account model:
// - Two account types: "individual" (public self-signup) and "organization_managed" (provisioned).
// - Roles: "platform_admin" | "org_admin" | "teacher" | "student" | "individual_user"
// - Org-managed users have username + temp password; email is optional.
// - Individual users have email; username is optional.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Organizations (mosque schools, institutes)
// ─────────────────────────────────────────────────────────────

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  logoUrl      String?
  contactEmail String?
  contactPhone String?
  address      String?
  timezone     String   @default("UTC")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users               User[]
  classes             Class[]
  plan                OrganizationPlan?
  courseAccess        OrgCourseAccess[]
  teacherCourseAccess TeacherCourseAccess[]

  @@index([isActive])
}

// Which CourseTemplates an organization has registered.
// availableToAll = true → all teachers can use it without individual assignment.
// availableToAll = false → only teachers in TeacherCourseAccess can use it.
model OrgCourseAccess {
  id               String   @id @default(cuid())
  organizationId   String
  courseTemplateId String
  availableToAll   Boolean  @default(false)
  grantedAt        DateTime @default(now())
  grantedById      String?

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courseTemplate CourseTemplate       @relation(fields: [courseTemplateId], references: [id], onDelete: Cascade)
  teacherAccess  TeacherCourseAccess[]

  @@unique([organizationId, courseTemplateId])
  @@index([organizationId])
  @@index([courseTemplateId])
}

// Per-teacher course assignment within an org.
model TeacherCourseAccess {
  id                String   @id @default(cuid())
  organizationId    String
  teacherProfileId  String
  courseTemplateId  String
  orgCourseAccessId String?
  grantedByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher        TeacherProfile  @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  courseTemplate CourseTemplate  @relation(fields: [courseTemplateId], references: [id], onDelete: Cascade)
  orgAccess      OrgCourseAccess? @relation(fields: [orgCourseAccessId], references: [id], onDelete: SetNull)

  @@unique([teacherProfileId, courseTemplateId])
  @@index([organizationId])
  @@index([teacherProfileId])
  @@index([courseTemplateId])
}

// ─────────────────────────────────────────────────────────────
// Identity & roles
// ─────────────────────────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  fullName     String
  // email is required for individual accounts; optional for org-managed
  email        String? @unique
  // username is required for org-managed accounts; optional for individual
  username     String? @unique
  passwordHash String
  // "individual" | "organization_managed"
  accountType  String  @default("individual")
  // "platform_admin" | "org_admin" | "teacher" | "student" | "individual_user"
  role         String
  organizationId          String?
  mustChangePassword      Boolean   @default(false)
  tempPasswordGeneratedAt DateTime?
  lastLoginAt             DateTime?
  isActive                Boolean   @default(true)
  profileImage            String?
  timezone                String    @default("UTC")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  organization Organization?  @relation(fields: [organizationId], references: [id])
  teacher      TeacherProfile?
  student      StudentProfile?
  sessions     Session[]
  announcements           Announcement[]
  createdReleaseRules     ReleaseRule[]       @relation("ReleaseRuleCreatedBy")
  createdAssignments      Assignment[]        @relation("AssignmentCreatedBy")
  enrolledStudents        ClassEnrollment[]   @relation("EnrolledBy")
  activityLogs            ActivityLog[]

  @@index([role])
  @@index([organizationId])
  @@index([accountType])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TeacherProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  bio              String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes      Class[]
  courseAccess TeacherCourseAccess[]
}

model StudentProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  dateOfBirth DateTime?
  guardianId  String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guardian         Guardian?                @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  enrollments      ClassEnrollment[]
  progress         StudentProgress[]
  quizAttempts     QuizAttempt[]
  examAttempts     ExamAttempt[]
  releaseOverrides StudentReleaseOverride[]

  @@index([guardianId])
}

// ─────────────────────────────────────────────────────────────
// Guardian/parent accounts (optional, for child enrollments)
// ─────────────────────────────────────────────────────────────

model Guardian {
  id           String   @id @default(cuid())
  fullName     String
  email        String?
  phone        String?
  relationship String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students StudentProfile[]

  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// Master Seerah content library
// ─────────────────────────────────────────────────────────────

model SeerahPart {
  id                   String  @id @default(cuid())
  partNumber           Int     @unique
  title                String
  slug                 String  @unique
  subtitle             String?
  era                  String
  shortDescription     String?
  longDescription      String?
  orderIndex           Int
  durationMinutes      Int?
  includedInEssentials Boolean @default(false)
  isPublished          Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assets              SeerahPartAsset[]
  courseTemplateItems CourseTemplateItem[]
  classCourseItems    ClassCourseItem[]
  quizzes             Quiz[]
  examLinks           ExamPartLink[]

  @@index([era])
  @@index([orderIndex])
}

model SeerahPartAsset {
  id           String   @id @default(cuid())
  seerahPartId String
  assetType    String
  title        String?
  url          String?
  filePath     String?
  assetOrder   Int      @default(0)
  metadataJson String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seerahPart SeerahPart @relation(fields: [seerahPartId], references: [id], onDelete: Cascade)

  @@index([seerahPartId])
  @@index([assetType])
}

// ─────────────────────────────────────────────────────────────
// Course templates (admin-authored reusable curricula)
// ─────────────────────────────────────────────────────────────

model CourseTemplate {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  description      String?
  createdByAdminId String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items           CourseTemplateItem[]
  classCourses    ClassCourse[]
  orgAccess       OrgCourseAccess[]
  teacherAccess   TeacherCourseAccess[]
}

model CourseTemplateItem {
  id               String   @id @default(cuid())
  courseTemplateId String
  seerahPartId     String
  moduleName       String?
  itemOrder        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  courseTemplate CourseTemplate @relation(fields: [courseTemplateId], references: [id], onDelete: Cascade)
  seerahPart     SeerahPart     @relation(fields: [seerahPartId], references: [id])

  @@index([courseTemplateId])
  @@index([itemOrder])
}

// ─────────────────────────────────────────────────────────────
// Classes (teacher-owned, student-enrolled)
// ─────────────────────────────────────────────────────────────

model Class {
  id               String    @id @default(cuid())
  organizationId   String?
  teacherId        String
  title            String
  slug             String    @unique
  description      String?
  bannerImage      String?
  startDate        DateTime?
  endDate          DateTime?
  status           String    @default("active")
  visibility       String    @default("private")
  joinCode         String    @unique
  allowAutoJoin    Boolean   @default(true)
  lockSequence     Boolean   @default(false)
  showLockedContent Boolean  @default(true)
  // Participant audience and requirements
  audienceType     String    @default("mixed")
  requiresGuardian Boolean   @default(false)
  genderRestriction String?
  ageMin           Int?
  ageMax           Int?
  capacity         Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization  Organization?   @relation(fields: [organizationId], references: [id])
  teacher       TeacherProfile  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments   ClassEnrollment[]
  classCourse   ClassCourse?
  releaseRules  ReleaseRule[]
  assignments   Assignment[]
  progress      StudentProgress[]
  quizzes       Quiz[]
  quizAttempts  QuizAttempt[]
  exams         Exam[]
  examAttempts  ExamAttempt[]
  announcements Announcement[]
  activityLogs  ActivityLog[]

  @@index([organizationId])
  @@index([teacherId])
  @@index([status])
  @@index([audienceType])
}

model ClassEnrollment {
  id               String    @id @default(cuid())
  classId          String
  studentId        String
  enrolledByUserId String?
  status           String    @default("active")
  joinedAt         DateTime  @default(now())
  removedAt        DateTime?

  class      Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrolledBy User?          @relation("EnrolledBy", fields: [enrolledByUserId], references: [id], onDelete: SetNull)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

model ClassCourse {
  id               String   @id @default(cuid())
  classId          String   @unique
  courseTemplateId String?
  title            String
  description      String?
  isCustom         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  class          Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  courseTemplate CourseTemplate?    @relation(fields: [courseTemplateId], references: [id])
  items          ClassCourseItem[]
}

model ClassCourseItem {
  id            String   @id @default(cuid())
  classCourseId String
  seerahPartId  String
  moduleName    String?
  itemOrder     Int
  isRequired    Boolean  @default(true)
  teacherNote   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  classCourse  ClassCourse       @relation(fields: [classCourseId], references: [id], onDelete: Cascade)
  seerahPart   SeerahPart        @relation(fields: [seerahPartId], references: [id])
  releaseRules ReleaseRule[]
  assignments  Assignment[]
  progress     StudentProgress[]

  @@index([classCourseId])
  @@index([itemOrder])
}

// ─────────────────────────────────────────────────────────────
// Release engine
// ─────────────────────────────────────────────────────────────

model ReleaseRule {
  id                 String    @id @default(cuid())
  classId            String
  classCourseItemId  String?
  targetType         String
  targetId           String?
  releaseMode        String
  scheduledAt        DateTime?
  conditionType      String?
  conditionValue     String?
  isReleased         Boolean   @default(false)
  releasedAt         DateTime?
  createdByTeacherId String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  class           Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  classCourseItem ClassCourseItem?  @relation(fields: [classCourseItemId], references: [id])
  createdBy       User              @relation("ReleaseRuleCreatedBy", fields: [createdByTeacherId], references: [id])
  overrides       StudentReleaseOverride[]

  @@index([classId])
  @@index([targetType])
  @@index([isReleased])
}

model StudentReleaseOverride {
  id             String    @id @default(cuid())
  releaseRuleId  String
  studentId      String
  isVisible      Boolean   @default(true)
  isUnlocked     Boolean   @default(false)
  availableFrom  DateTime?
  availableUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  releaseRule ReleaseRule    @relation(fields: [releaseRuleId], references: [id], onDelete: Cascade)
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([releaseRuleId, studentId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────
// Assignments
// ─────────────────────────────────────────────────────────────

model Assignment {
  id                 String    @id @default(cuid())
  classId            String
  classCourseItemId  String?
  assignmentType     String
  title              String
  description        String?
  dueAt              DateTime?
  availableFrom      DateTime?
  availableUntil     DateTime?
  isRequired         Boolean   @default(true)
  createdByTeacherId String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  class           Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  classCourseItem ClassCourseItem? @relation(fields: [classCourseItemId], references: [id])
  createdBy       User             @relation("AssignmentCreatedBy", fields: [createdByTeacherId], references: [id])

  @@index([classId])
  @@index([dueAt])
}

// ─────────────────────────────────────────────────────────────
// Progress tracking
// ─────────────────────────────────────────────────────────────

model StudentProgress {
  id                   String    @id @default(cuid())
  classId              String
  studentId            String
  classCourseItemId    String
  status               String    @default("locked")
  startedAt            DateTime?
  completedAt          DateTime?
  lastAccessedAt       DateTime?
  completionPercentage Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  class           Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classCourseItem ClassCourseItem @relation(fields: [classCourseItemId], references: [id], onDelete: Cascade)

  @@unique([studentId, classCourseItemId])
  @@index([classId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// Quizzes
// ─────────────────────────────────────────────────────────────

model Quiz {
  id               String   @id @default(cuid())
  seerahPartId     String?
  classId          String?
  title            String
  description      String?
  quizType         String   @default("part_quiz")
  passingScore     Int      @default(70)
  maxAttempts      Int?
  timeLimitMinutes Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  seerahPart SeerahPart?    @relation(fields: [seerahPartId], references: [id])
  class      Class?         @relation(fields: [classId], references: [id], onDelete: Cascade)
  questions  QuizQuestion[]
  attempts   QuizAttempt[]

  @@index([seerahPartId])
  @@index([classId])
}

model QuizQuestion {
  id           String   @id @default(cuid())
  quizId       String
  questionText String
  questionType String   @default("multiple_choice")
  explanation  String?
  orderIndex   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizOption {
  id         String   @id @default(cuid())
  questionId String
  optionText String
  isCorrect  Boolean  @default(false)
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuizAnswer[]

  @@index([questionId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  classId     String?
  studentId   String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  score       Int?
  passed      Boolean?
  status      String    @default("in_progress")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  quiz    Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  class   Class?          @relation(fields: [classId], references: [id])
  student StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
}

model QuizAnswer {
  id               String   @id @default(cuid())
  quizAttemptId    String
  questionId       String
  selectedOptionId String?
  answerText       String?
  isCorrect        Boolean?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempt        QuizAttempt  @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuizOption?  @relation(fields: [selectedOptionId], references: [id])

  @@index([quizAttemptId])
}

// ─────────────────────────────────────────────────────────────
// Exams
// ─────────────────────────────────────────────────────────────

model Exam {
  id             String    @id @default(cuid())
  classId        String
  title          String
  description    String?
  examScope      String    @default("module")
  passingScore   Int       @default(70)
  availableFrom  DateTime?
  availableUntil DateTime?
  maxAttempts    Int?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  partLinks ExamPartLink[]
  attempts  ExamAttempt[]

  @@index([classId])
}

model ExamPartLink {
  id           String   @id @default(cuid())
  examId       String
  seerahPartId String
  createdAt    DateTime @default(now())

  exam       Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  seerahPart SeerahPart @relation(fields: [seerahPartId], references: [id])

  @@unique([examId, seerahPartId])
  @@index([examId])
}

model ExamAttempt {
  id          String    @id @default(cuid())
  examId      String
  classId     String
  studentId   String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  score       Int?
  passed      Boolean?
  status      String    @default("in_progress")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  exam    Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  class   Class           @relation(fields: [classId], references: [id])
  student StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────
// Announcements & activity
// ─────────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  classId     String
  teacherId   String
  title       String
  body        String
  isPublished Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher User  @relation(fields: [teacherId], references: [id])

  @@index([classId])
  @@index([publishedAt])
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String?
  classId      String?
  activityType String
  entityType   String?
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  class Class? @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([classId])
  @@index([activityType])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// Organization / school access requests (public lead capture)
// ─────────────────────────────────────────────────────────────

model OrganizationAccessRequest {
  id                 String    @id @default(cuid())
  organizationName   String
  contactName        String
  contactEmail       String
  contactPhone       String?
  country            String?
  city               String?
  // e.g. "masjid" | "islamic_school" | "homeschool_group" | "institute" | "other"
  organizationType   String?
  estimatedStudents  String?
  message            String?
  // "new" | "contacted" | "approved" | "rejected"
  status             String    @default("new")
  approvedAt         DateTime?
  approvedById       String?
  rejectedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// Organization plan / limits (created at approval time)
// ─────────────────────────────────────────────────────────────

model OrganizationPlan {
  id             String    @id @default(cuid())
  organizationId String    @unique
  // "pilot" | "standard" | "premium"
  planType       String    @default("pilot")
  studentLimit   Int       @default(50)
  teacherLimit   Int       @default(3)
  // "active" | "suspended" | "expired"
  status         String    @default("active")
  startsAt       DateTime  @default(now())
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
}
