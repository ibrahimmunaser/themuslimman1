// Seerah LMS — Simplified Direct-to-Consumer Platform
//
// Database: Supabase PostgreSQL (session pooler, aws-1-us-west-2)
//
// Platform model:
// - Platform admins (you) manage content
// - Students sign up directly and learn
// - No organizations, teachers, or institutional features
// - Usernames auto-generated from names: firstname initial + lastname
// - Email-based signup with automatic welcome email

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// User accounts - platform admins and students only
// ─────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  fullName            String
  email               String    @unique
  username            String    @unique
  passwordHash        String?
  role                String    // "platform_admin" | "student"
  emailVerified       Boolean   @default(false)
  verificationToken   String?   @unique
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  lastLoginAt         DateTime?
  isActive            Boolean   @default(true)
  profileImage        String?
  timezone            String    @default("UTC")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  student      StudentProfile?
  sessions     Session[]
  activityLogs ActivityLog[]

  @@index([role])
  @@index([email])
  @@index([username])
  @@index([verificationToken])
  @@index([passwordResetToken])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model StudentProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  dateOfBirth DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments      ClassEnrollment[]
  progress         StudentProgress[]
  quizAttempts     QuizAttempt[]
  examAttempts     ExamAttempt[]
  releaseOverrides StudentReleaseOverride[]
}

// ─────────────────────────────────────────────────────────────
// Master Seerah content library
// ─────────────────────────────────────────────────────────────

model SeerahPart {
  id                   String  @id @default(cuid())
  partNumber           Int     @unique
  title                String
  slug                 String  @unique
  subtitle             String?
  era                  String
  shortDescription     String?
  longDescription      String?
  orderIndex           Int
  durationMinutes      Int?
  includedInEssentials Boolean @default(false)
  isPublished          Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assets              SeerahPartAsset[]
  courseTemplateItems CourseTemplateItem[]
  classCourseItems    ClassCourseItem[]
  quizzes             Quiz[]
  examLinks           ExamPartLink[]

  @@index([era])
  @@index([orderIndex])
}

model SeerahPartAsset {
  id           String   @id @default(cuid())
  seerahPartId String
  assetType    String
  title        String?
  url          String?
  filePath     String?
  assetOrder   Int      @default(0)
  metadataJson String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seerahPart SeerahPart @relation(fields: [seerahPartId], references: [id], onDelete: Cascade)

  @@index([seerahPartId])
  @@index([assetType])
}

// ─────────────────────────────────────────────────────────────
// Course templates (admin-created learning paths)
// ─────────────────────────────────────────────────────────────

model CourseTemplate {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items        CourseTemplateItem[]
  classCourses ClassCourse[]
}

model CourseTemplateItem {
  id               String   @id @default(cuid())
  courseTemplateId String
  seerahPartId     String
  moduleName       String?
  itemOrder        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  courseTemplate CourseTemplate @relation(fields: [courseTemplateId], references: [id], onDelete: Cascade)
  seerahPart     SeerahPart     @relation(fields: [seerahPartId], references: [id])

  @@index([courseTemplateId])
  @@index([itemOrder])
}

// ─────────────────────────────────────────────────────────────
// Classes (self-paced courses students can enroll in)
// ─────────────────────────────────────────────────────────────

model Class {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  description       String?
  bannerImage       String?
  startDate         DateTime?
  endDate           DateTime?
  status            String    @default("active")
  visibility        String    @default("public")
  allowSelfEnroll   Boolean   @default(true)
  lockSequence      Boolean   @default(false)
  showLockedContent Boolean   @default(true)
  capacity          Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  enrollments   ClassEnrollment[]
  classCourse   ClassCourse?
  releaseRules  ReleaseRule[]
  assignments   Assignment[]
  progress      StudentProgress[]
  quizzes       Quiz[]
  quizAttempts  QuizAttempt[]
  exams         Exam[]
  examAttempts  ExamAttempt[]
  activityLogs  ActivityLog[]

  @@index([status])
  @@index([visibility])
}

model ClassEnrollment {
  id        String    @id @default(cuid())
  classId   String
  studentId String
  status    String    @default("active")
  joinedAt  DateTime  @default(now())
  removedAt DateTime?

  class   Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

model ClassCourse {
  id               String   @id @default(cuid())
  classId          String   @unique
  courseTemplateId String?
  title            String
  description      String?
  isCustom         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  class          Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  courseTemplate CourseTemplate?    @relation(fields: [courseTemplateId], references: [id])
  items          ClassCourseItem[]
}

model ClassCourseItem {
  id            String   @id @default(cuid())
  classCourseId String
  seerahPartId  String
  moduleName    String?
  itemOrder     Int
  isRequired    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  classCourse  ClassCourse       @relation(fields: [classCourseId], references: [id], onDelete: Cascade)
  seerahPart   SeerahPart        @relation(fields: [seerahPartId], references: [id])
  releaseRules ReleaseRule[]
  assignments  Assignment[]
  progress     StudentProgress[]

  @@index([classCourseId])
  @@index([itemOrder])
}

// ─────────────────────────────────────────────────────────────
// Release engine
// ─────────────────────────────────────────────────────────────

model ReleaseRule {
  id                String    @id @default(cuid())
  classId           String
  classCourseItemId String?
  targetType        String
  targetId          String?
  releaseMode       String
  scheduledAt       DateTime?
  conditionType     String?
  conditionValue    String?
  isReleased        Boolean   @default(false)
  releasedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  class           Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classCourseItem ClassCourseItem?         @relation(fields: [classCourseItemId], references: [id])
  overrides       StudentReleaseOverride[]

  @@index([classId])
  @@index([targetType])
  @@index([isReleased])
}

model StudentReleaseOverride {
  id             String    @id @default(cuid())
  releaseRuleId  String
  studentId      String
  isVisible      Boolean   @default(true)
  isUnlocked     Boolean   @default(false)
  availableFrom  DateTime?
  availableUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  releaseRule ReleaseRule    @relation(fields: [releaseRuleId], references: [id], onDelete: Cascade)
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([releaseRuleId, studentId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────
// Assignments
// ─────────────────────────────────────────────────────────────

model Assignment {
  id                String    @id @default(cuid())
  classId           String
  classCourseItemId String?
  assignmentType    String
  title             String
  description       String?
  dueAt             DateTime?
  availableFrom     DateTime?
  availableUntil    DateTime?
  isRequired        Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  class           Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  classCourseItem ClassCourseItem? @relation(fields: [classCourseItemId], references: [id])

  @@index([classId])
  @@index([dueAt])
}

// ─────────────────────────────────────────────────────────────
// Progress tracking
// ─────────────────────────────────────────────────────────────

model StudentProgress {
  id                   String    @id @default(cuid())
  classId              String
  studentId            String
  classCourseItemId    String
  status               String    @default("locked")
  startedAt            DateTime?
  completedAt          DateTime?
  lastAccessedAt       DateTime?
  completionPercentage Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  class           Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classCourseItem ClassCourseItem @relation(fields: [classCourseItemId], references: [id], onDelete: Cascade)

  @@unique([studentId, classCourseItemId])
  @@index([classId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// Quizzes
// ─────────────────────────────────────────────────────────────

model Quiz {
  id               String   @id @default(cuid())
  seerahPartId     String?
  classId          String?
  title            String
  description      String?
  quizType         String   @default("part_quiz")
  passingScore     Int      @default(70)
  maxAttempts      Int?
  timeLimitMinutes Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  seerahPart SeerahPart?    @relation(fields: [seerahPartId], references: [id])
  class      Class?         @relation(fields: [classId], references: [id], onDelete: Cascade)
  questions  QuizQuestion[]
  attempts   QuizAttempt[]

  @@index([seerahPartId])
  @@index([classId])
}

model QuizQuestion {
  id           String   @id @default(cuid())
  quizId       String
  questionText String
  questionType String   @default("multiple_choice")
  explanation  String?
  orderIndex   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizOption {
  id         String   @id @default(cuid())
  questionId String
  optionText String
  isCorrect  Boolean  @default(false)
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuizAnswer[]

  @@index([questionId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  classId     String?
  studentId   String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  score       Int?
  passed      Boolean?
  status      String    @default("in_progress")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  quiz    Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  class   Class?          @relation(fields: [classId], references: [id])
  student StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
}

model QuizAnswer {
  id               String   @id @default(cuid())
  quizAttemptId    String
  questionId       String
  selectedOptionId String?
  answerText       String?
  isCorrect        Boolean?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempt        QuizAttempt  @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuizOption?  @relation(fields: [selectedOptionId], references: [id])

  @@index([quizAttemptId])
}

// ─────────────────────────────────────────────────────────────
// Exams
// ─────────────────────────────────────────────────────────────

model Exam {
  id             String    @id @default(cuid())
  classId        String
  title          String
  description    String?
  examScope      String    @default("module")
  passingScore   Int       @default(70)
  availableFrom  DateTime?
  availableUntil DateTime?
  maxAttempts    Int?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  partLinks ExamPartLink[]
  attempts  ExamAttempt[]

  @@index([classId])
}

model ExamPartLink {
  id           String   @id @default(cuid())
  examId       String
  seerahPartId String
  createdAt    DateTime @default(now())

  exam       Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  seerahPart SeerahPart @relation(fields: [seerahPartId], references: [id])

  @@unique([examId, seerahPartId])
  @@index([examId])
}

model ExamAttempt {
  id          String    @id @default(cuid())
  examId      String
  classId     String
  studentId   String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  score       Int?
  passed      Boolean?
  status      String    @default("in_progress")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  exam    Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  class   Class           @relation(fields: [classId], references: [id])
  student StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────
// Activity logs
// ─────────────────────────────────────────────────────────────

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String?
  classId      String?
  activityType String
  entityType   String?
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  class Class? @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([classId])
  @@index([activityType])
  @@index([createdAt])
}
