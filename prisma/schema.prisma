generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ActivityLog {
  id           String   @id
  userId       String?
  classId      String?
  activityType String
  entityType   String?
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())
  class        Class?   @relation(fields: [classId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])

  @@index([activityType])
  @@index([classId])
  @@index([createdAt])
  @@index([userId])
}

model Assignment {
  id                String           @id
  classId           String
  classCourseItemId String?
  assignmentType    String
  title             String
  description       String?
  dueAt             DateTime?
  availableFrom     DateTime?
  availableUntil    DateTime?
  isRequired        Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  classCourseItem   ClassCourseItem? @relation(fields: [classCourseItemId], references: [id])
  class             Class            @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([dueAt])
}

model Class {
  id                String            @id
  title             String
  slug              String            @unique
  description       String?
  bannerImage       String?
  startDate         DateTime?
  endDate           DateTime?
  status            String            @default("active")
  visibility        String            @default("public")
  allowSelfEnroll   Boolean           @default(true)
  lockSequence      Boolean           @default(false)
  showLockedContent Boolean           @default(true)
  capacity          Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  activityLogs      ActivityLog[]
  assignments       Assignment[]
  classCourse       ClassCourse?
  enrollments       ClassEnrollment[]
  exams             Exam[]
  examAttempts      ExamAttempt[]
  quizzes           Quiz[]
  quizAttempts      QuizAttempt[]
  releaseRules      ReleaseRule[]
  studentProgress   StudentProgress[]

  @@index([status])
  @@index([visibility])
}

model ClassCourse {
  id               String            @id
  classId          String            @unique
  courseTemplateId String?
  title            String
  description      String?
  isCustom         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  courseTemplate   CourseTemplate?   @relation(fields: [courseTemplateId], references: [id])
  items            ClassCourseItem[]
}

model ClassCourseItem {
  id              String            @id
  classCourseId   String
  seerahPartId    String
  moduleName      String?
  itemOrder       Int
  isRequired      Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  assignments     Assignment[]
  classCourse     ClassCourse       @relation(fields: [classCourseId], references: [id], onDelete: Cascade)
  seerahPart      SeerahPart        @relation(fields: [seerahPartId], references: [id])
  releaseRules    ReleaseRule[]
  studentProgress StudentProgress[]

  @@index([classCourseId])
  @@index([itemOrder])
}

model ClassEnrollment {
  id             String         @id
  classId        String
  studentId      String
  status         String         @default("active")
  joinedAt       DateTime       @default(now())
  removedAt      DateTime?
  class          Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

model CourseTemplate {
  id          String               @id
  title       String
  slug        String               @unique
  description String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime
  classCourses ClassCourse[]
  items        CourseTemplateItem[]
}

model CourseTemplateItem {
  id               String         @id
  courseTemplateId String
  seerahPartId     String
  moduleName       String?
  itemOrder        Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  courseTemplate   CourseTemplate @relation(fields: [courseTemplateId], references: [id], onDelete: Cascade)
  seerahPart       SeerahPart     @relation(fields: [seerahPartId], references: [id])

  @@index([courseTemplateId])
  @@index([itemOrder])
}

model Exam {
  id             String         @id
  classId        String
  title          String
  description    String?
  examScope      String         @default("module")
  passingScore   Int            @default(70)
  availableFrom  DateTime?
  availableUntil DateTime?
  maxAttempts    Int?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  class          Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  examAttempts   ExamAttempt[]
  examPartLinks  ExamPartLink[]

  @@index([classId])
}

model ExamAttempt {
  id             String         @id
  examId         String
  classId        String
  studentId      String
  startedAt      DateTime       @default(now())
  submittedAt    DateTime?
  score          Int?
  passed         Boolean?
  status         String         @default("in_progress")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  class          Class          @relation(fields: [classId], references: [id])
  exam           Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
}

model ExamPartLink {
  id           String     @id
  examId       String
  seerahPartId String
  createdAt    DateTime   @default(now())
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  seerahPart   SeerahPart @relation(fields: [seerahPartId], references: [id])

  @@unique([examId, seerahPartId])
  @@index([examId])
}

model GiftPurchase {
  id                                      String    @id
  stripePaymentIntentId                   String    @unique
  purchaserUserId                         String?
  purchaserEmail                          String
  recipientEmail                          String
  recipientName                           String?
  giftMessage                             String?
  claimTokenHash                          String?   @unique
  claimedByUserId                         String?
  claimedAt                               DateTime?
  emailSentAt                             DateTime?
  createdAt                               DateTime  @default(now())
  expiresAt                               DateTime?
  status                                  String    @default("pending")
  /// "complete" (Individual Lifetime $99) | "family" (Family Lifetime $199)
  planId                                  String    @default("complete")
  User_GiftPurchase_claimedByUserIdToUser User?     @relation("GiftPurchase_claimedByUserIdToUser", fields: [claimedByUserId], references: [id])
  User_GiftPurchase_purchaserUserIdToUser User?     @relation("GiftPurchase_purchaserUserIdToUser", fields: [purchaserUserId], references: [id])

  @@index([purchaserUserId])
  @@index([recipientEmail])
  @@index([status])
}

model InfluencerClick {
  id        String   @id
  creator   String
  clickedAt DateTime @default(now())

  @@index([clickedAt])
  @@index([creator])
}

model LearnerProfile {
  id           String         @id
  userId       String
  displayName  String
  avatar       String?
  isDefault    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  partProgress PartProgress[]
  studySessions StudySession[]

  @@index([userId])
}

model PartProgress {
  id                 String         @id
  userId             String
  partNumber         Int
  status             String         @default("not_started")
  lastAccessedAt     DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime
  briefingOpened     Boolean        @default(false)
  flashcardsReviewed Boolean        @default(false)
  masteredAt         DateTime?
  openedAssets       String         @default("[]")
  quizAttempts       Int            @default(0)
  quizBestScore      Int?
  quizCompleted      Boolean        @default(false)
  quizPassed         Boolean        @default(false)
  quizScore          Int?
  videoCompleted     Boolean        @default(false)
  videoWatchPercent  Int            @default(0)
  learnerProfileId   String
  learnerProfile     LearnerProfile @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([learnerProfileId, partNumber])
  @@index([learnerProfileId])
  @@index([status])
  @@index([userId])
}

model MobilePurchase {
  id               String    @id
  userId           String
  /// "apple" | "google"
  platform         String
  /// Exact product ID registered in App Store Connect / Play Console
  productId        String
  /// iOS: transactionId — Android: orderId
  transactionId    String    @unique
  /// Android only — the purchase token used for API verification
  purchaseToken    String?
  /// "individual" | "family"
  planType         String
  /// "lifetime" | "subscription"
  purchaseType     String
  /// "active" | "expired" | "cancelled" | "refunded"
  status           String    @default("active")
  /// null for lifetime purchases
  currentPeriodEnd DateTime?
  /// Full JSON response from Apple/Google stored for audit trail
  rawResponse      String?
  verifiedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([status])
}

model Purchase {
  id                    String   @id
  userId                String
  planId                String
  planName              String
  amount                Int
  currency              String   @default("usd")
  status                String   @default("pending")
  stripePaymentIntentId String   @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  creator               String?
  promoCode             String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([creator])
  @@index([promoCode])
  @@index([status])
  @@index([userId])
}

model Quiz {
  id               String         @id
  seerahPartId     String?
  classId          String?
  title            String
  description      String?
  quizType         String         @default("part_quiz")
  passingScore     Int            @default(70)
  maxAttempts      Int?
  timeLimitMinutes Int?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  class            Class?         @relation(fields: [classId], references: [id], onDelete: Cascade)
  seerahPart       SeerahPart?    @relation(fields: [seerahPartId], references: [id])
  quizAttempts     QuizAttempt[]
  questions        QuizQuestion[]

  @@index([classId])
  @@index([seerahPartId])
}

model QuizAnswer {
  id               String       @id
  quizAttemptId    String
  questionId       String
  selectedOptionId String?
  answerText       String?
  isCorrect        Boolean?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime
  question         QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quizAttempt      QuizAttempt  @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  selectedOption   QuizOption?  @relation(fields: [selectedOptionId], references: [id])

  @@index([quizAttemptId])
}

model QuizAttempt {
  id             String         @id
  quizId         String
  classId        String?
  studentId      String
  startedAt      DateTime       @default(now())
  submittedAt    DateTime?
  score          Int?
  passed         Boolean?
  status         String         @default("in_progress")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  answers        QuizAnswer[]
  class          Class?         @relation(fields: [classId], references: [id])
  quiz           Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([studentId])
}

model QuizOption {
  id           String       @id
  questionId   String
  optionText   String
  isCorrect    Boolean      @default(false)
  orderIndex   Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  quizAnswers  QuizAnswer[]
  quizQuestion QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizQuestion {
  id           String       @id
  quizId       String
  questionText String
  questionType String       @default("multiple_choice")
  explanation  String?
  orderIndex   Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  quizAnswers  QuizAnswer[]
  options      QuizOption[]
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model ReleaseRule {
  id                     String                   @id
  classId                String
  classCourseItemId      String?
  targetType             String
  targetId               String?
  releaseMode            String
  scheduledAt            DateTime?
  conditionType          String?
  conditionValue         String?
  isReleased             Boolean                  @default(false)
  releasedAt             DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  classCourseItem        ClassCourseItem?         @relation(fields: [classCourseItemId], references: [id])
  class                  Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentReleaseOverrides StudentReleaseOverride[]

  @@index([classId])
  @@index([isReleased])
  @@index([targetType])
}

model SeerahPart {
  id                   String               @id
  partNumber           Int                  @unique
  title                String
  slug                 String               @unique
  subtitle             String?
  era                  String
  shortDescription     String?
  longDescription      String?
  orderIndex           Int
  durationMinutes      Int?
  includedInEssentials Boolean              @default(false)
  isPublished          Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime
  classCourseItems     ClassCourseItem[]
  courseTemplateItems  CourseTemplateItem[]
  examPartLinks        ExamPartLink[]
  quizzes              Quiz[]
  assets               SeerahPartAsset[]

  @@index([era])
  @@index([orderIndex])
}

model SeerahPartAsset {
  id           String     @id
  seerahPartId String
  assetType    String
  title        String?
  url          String?
  filePath     String?
  assetOrder   Int        @default(0)
  metadataJson String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  seerahPart   SeerahPart @relation(fields: [seerahPartId], references: [id], onDelete: Cascade)

  @@index([assetType])
  @@index([seerahPartId])
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model StudentProfile {
  id                     String                   @id
  userId                 String                   @unique
  dateOfBirth            DateTime?
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  enrollments            ClassEnrollment[]
  examAttempts           ExamAttempt[]
  quizAttempts           QuizAttempt[]
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProgress        StudentProgress[]
  studentReleaseOverrides StudentReleaseOverride[]
}

model StudentProgress {
  id                   String          @id
  classId              String
  studentId            String
  classCourseItemId    String
  status               String          @default("locked")
  startedAt            DateTime?
  completedAt          DateTime?
  lastAccessedAt       DateTime?
  completionPercentage Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime
  classCourseItem      ClassCourseItem @relation(fields: [classCourseItemId], references: [id], onDelete: Cascade)
  class                Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentProfile       StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classCourseItemId])
  @@index([classId])
  @@index([status])
}

model StudentReleaseOverride {
  id             String         @id
  releaseRuleId  String
  studentId      String
  isVisible      Boolean        @default(true)
  isUnlocked     Boolean        @default(false)
  availableFrom  DateTime?
  availableUntil DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  releaseRule    ReleaseRule    @relation(fields: [releaseRuleId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([releaseRuleId, studentId])
  @@index([studentId])
}

model StudySession {
  id               String          @id
  userId           String
  partNumber       Int
  secondsTracked   Int             @default(0)
  startedAt        DateTime        @default(now())
  lastUpdatedAt    DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  learnerProfileId String?
  learnerProfile   LearnerProfile? @relation(fields: [learnerProfileId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([learnerProfileId])
  @@index([partNumber])
  @@index([startedAt])
  @@index([userId])
}

model Subscription {
  id                   String    @id
  userId               String
  stripeCustomerId     String
  stripeSubscriptionId String    @unique
  stripePriceId        String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  creator              String?
  promoCode            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  /// Set on first invoice.payment_failed (billing_reason=subscription_cycle); cleared on
  /// payment success. Access is granted while status=past_due AND gracePeriodEndsAt >= now.
  gracePeriodEndsAt         DateTime?
  /// Synced with invoice.attempt_count for the currently-failing invoice.
  /// Reset to 0 when the invoice is paid or a new billing cycle begins.
  renewalAttemptCount       Int       @default(0)
  /// Timestamp of the most recent invoice.payment_failed event.
  lastPaymentFailedAt       DateTime?
  /// Stripe invoice ID of the invoice that triggered the failure state.
  /// A new invoice ID (new billing cycle) resets the grace period window.
  lastFailedInvoiceId       String?
  /// Stripe event ID of the last invoice.payment_failed delivery that actually
  /// mutated this row. Kept for observability/debugging only — the actual
  /// delivery-idempotency guarantee comes from the unique constraint on
  /// StripeWebhookEvent.stripeEventId, checked inside the same DB transaction.
  lastFailedStripeEventId   String?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([creator])
  @@index([gracePeriodEndsAt])
  @@index([lastFailedInvoiceId])
  @@index([status])
  @@index([userId])
}

/// One-trial-per-user-per-course durable claim (BLK-02 fix).
///
/// A DB unique constraint (not a read-then-act query) is required here because
/// `stripe.subscriptions.create()` is an external network call that a Prisma
/// transaction cannot atomically protect. Two concurrent `setup_intent.succeeded`
/// deliveries — e.g. from two SetupIntents created by two browser tabs — could
/// otherwise both observe "no Subscription row yet" and both create a live
/// Stripe trial subscription.
///
/// The claim is taken (DB-only, no network call) BEFORE any Stripe subscription
/// is created:
///  - unique(userId, courseKey): only one SetupIntent may ever win the claim for
///    a given user+course. The loser of a race never reaches stripe.subscriptions.create.
///  - unique(setupIntentId): a given SetupIntent can only ever be linked to one claim.
///
/// stripeSubId starts null (claim taken, Stripe call not made yet) and is filled
/// in by the SAME short transaction that upserts the local Subscription row,
/// once stripe.subscriptions.create (called with idempotencyKey
/// `trial-subscription:${setupIntentId}`) succeeds. A null stripeSubId on an
/// existing row for the SAME setupIntentId means "claimed but not finished yet"
/// (e.g. a prior DB transaction failed after Stripe already created the
/// subscription) — recoverable by retrying with the same idempotency key.
model TrialEligibility {
  id            String    @id
  userId        String
  courseKey     String
  setupIntentId String
  stripeSubId   String?
  createdAt     DateTime  @default(now())

  @@unique([userId, courseKey])
  @@unique([setupIntentId])
}

/// Durable, transactionally-consistent record of processed Stripe webhook
/// event IDs. Used to make sensitive webhook handlers (currently:
/// invoice.payment_failed / invoice.payment_action_required, setup_intent.succeeded
/// for trial provisioning) safe against:
///  - Stripe re-delivering the exact same event (evt_xxx) after a timeout
///  - Two webhook workers processing the same delivery concurrently
///
/// The unique constraint on stripeEventId is the actual correctness
/// mechanism: inserting this row happens inside the same DB transaction as
/// the Subscription update, so a concurrent duplicate insert fails with a
/// unique-violation and that worker returns without repeating side effects
/// (no double counters, no duplicate emails).
model StripeWebhookEvent {
  id            String   @id
  stripeEventId String   @unique
  eventType     String
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
}

model EmailOutreachLog {
  id           String    @id
  userId       String?
  name         String
  email        String
  outreachType String    // "NO_PLAN_MANUAL"
  subject      String
  status       String    // "SENT" | "FAILED" | "SKIPPED"
  sentAt       DateTime  @default(now())
  error        String?
  createdAt    DateTime  @default(now())
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([outreachType, status])
  @@index([sentAt])
  @@index([userId])
}

model EmailUnsubscribe {
  id             String    @id
  email          String    @unique
  token          String    @unique
  unsubscribed   Boolean   @default(false)
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@index([unsubscribed])
}

model EmailAutomationEvent {
  id        String   @id
  userId    String
  email     String
  flowType  String   // e.g. "NO_PLAN_RECOVERY"
  step      Int
  subject   String
  status    String   // "SENT" | "FAILED" | "SKIPPED"
  sentAt    DateTime @default(now())
  error     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, flowType, step])
  @@index([flowType, step])
  @@index([sentAt])
  @@index([status])
  @@index([userId])
}

model InfluencerEvent {
  id        String   @id
  creator   String
  eventType String
  sessionId String
  visitorId String
  route     String?
  plan      String?
  promoCode String?
  amount    Int?
  userEmail String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([creator, eventType])
  @@index([creator, sessionId])
  @@index([creator, visitorId])
  @@index([createdAt])
}

model SupportTicket {
  id        String   @id
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

model SeerahCheckupLead {
  id                String    @id @default(cuid())
  name              String?
  email             String
  phone             String?
  answers           Json
  score             Int
  resultType        String    // "scattered" | "partial" | "strong"
  recommendedPlan   String
  openText          String?
  sessionId         String?
  mainObjection     String?
  audienceType      String?   // "self" | "family" | "self_and_family" | "group"
  influencer        String?
  quizVersion       String?   @default("1.0")
  source            String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  clickedCheckout   Boolean   @default(false)
  checkoutClickedAt DateTime?
  part1ClickedAt    DateTime?
  purchasedAt       DateTime?
  unsubscribedAt    DateTime?
  createdAt         DateTime  @default(now())
  checkupEmailEvents CheckupEmailEvent[]

  @@index([email])
  @@index([createdAt])
  @@index([source])
  @@index([checkoutClickedAt])
}

model CheckupEmailEvent {
  id        String            @id
  leadId    String
  email     String
  flowType  String            // "CHECKUP_FOLLOWUP"
  step      Int               // 1=2h, 2=24h, 3=72h, 4=checkout_recovery
  subject   String
  status    String            // "SENT" | "FAILED" | "SKIPPED"
  sentAt    DateTime          @default(now())
  error     String?
  createdAt DateTime          @default(now())
  lead      SeerahCheckupLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, flowType, step])
  @@index([flowType, step, status])
  @@index([leadId])
  @@index([sentAt])
  @@index([email])
}

model User {
  id                                              String           @id
  fullName                                        String
  email                                           String           @unique
  passwordHash                                    String?
  role                                            String
