generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model ActivityLog {
  id           String   @id
  userId       String?
  classId      String?
  activityType String
  entityType   String?
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())
  Class        Class?   @relation(fields: [classId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])

  @@index([activityType])
  @@index([classId])
  @@index([createdAt])
  @@index([userId])
}

model Assignment {
  id                String           @id
  classId           String
  classCourseItemId String?
  assignmentType    String
  title             String
  description       String?
  dueAt             DateTime?
  availableFrom     DateTime?
  availableUntil    DateTime?
  isRequired        Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  ClassCourseItem   ClassCourseItem? @relation(fields: [classCourseItemId], references: [id])
  Class             Class            @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([dueAt])
}

model Class {
  id                String            @id
  title             String
  slug              String            @unique
  description       String?
  bannerImage       String?
  startDate         DateTime?
  endDate           DateTime?
  status            String            @default("active")
  visibility        String            @default("public")
  allowSelfEnroll   Boolean           @default(true)
  lockSequence      Boolean           @default(false)
  showLockedContent Boolean           @default(true)
  capacity          Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  ActivityLog       ActivityLog[]
  Assignment        Assignment[]
  ClassCourse       ClassCourse?
  ClassEnrollment   ClassEnrollment[]
  Exam              Exam[]
  ExamAttempt       ExamAttempt[]
  Quiz              Quiz[]
  QuizAttempt       QuizAttempt[]
  ReleaseRule       ReleaseRule[]
  StudentProgress   StudentProgress[]

  @@index([status])
  @@index([visibility])
}

model ClassCourse {
  id               String            @id
  classId          String            @unique
  courseTemplateId String?
  title            String
  description      String?
  isCustom         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  Class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  CourseTemplate   CourseTemplate?   @relation(fields: [courseTemplateId], references: [id])
  ClassCourseItem  ClassCourseItem[]
}

model ClassCourseItem {
  id              String            @id
  classCourseId   String
  seerahPartId    String
  moduleName      String?
  itemOrder       Int
  isRequired      Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Assignment      Assignment[]
  ClassCourse     ClassCourse       @relation(fields: [classCourseId], references: [id], onDelete: Cascade)
  SeerahPart      SeerahPart        @relation(fields: [seerahPartId], references: [id])
  ReleaseRule     ReleaseRule[]
  StudentProgress StudentProgress[]

  @@index([classCourseId])
  @@index([itemOrder])
}

model ClassEnrollment {
  id             String         @id
  classId        String
  studentId      String
  status         String         @default("active")
  joinedAt       DateTime       @default(now())
  removedAt      DateTime?
  Class          Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

model CourseTemplate {
  id                 String               @id
  title              String
  slug               String               @unique
  description        String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  ClassCourse        ClassCourse[]
  CourseTemplateItem CourseTemplateItem[]
}

model CourseTemplateItem {
  id               String         @id
  courseTemplateId String
  seerahPartId     String
  moduleName       String?
  itemOrder        Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  CourseTemplate   CourseTemplate @relation(fields: [courseTemplateId], references: [id], onDelete: Cascade)
  SeerahPart       SeerahPart     @relation(fields: [seerahPartId], references: [id])

  @@index([courseTemplateId])
  @@index([itemOrder])
}

model Exam {
  id             String         @id
  classId        String
  title          String
  description    String?
  examScope      String         @default("module")
  passingScore   Int            @default(70)
  availableFrom  DateTime?
  availableUntil DateTime?
  maxAttempts    Int?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  Class          Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  ExamAttempt    ExamAttempt[]
  ExamPartLink   ExamPartLink[]

  @@index([classId])
}

model ExamAttempt {
  id             String         @id
  examId         String
  classId        String
  studentId      String
  startedAt      DateTime       @default(now())
  submittedAt    DateTime?
  score          Int?
  passed         Boolean?
  status         String         @default("in_progress")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  Class          Class          @relation(fields: [classId], references: [id])
  Exam           Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
}

model ExamPartLink {
  id           String     @id
  examId       String
  seerahPartId String
  createdAt    DateTime   @default(now())
  Exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  SeerahPart   SeerahPart @relation(fields: [seerahPartId], references: [id])

  @@unique([examId, seerahPartId])
  @@index([examId])
}

model GiftPurchase {
  id                                      String    @id
  stripePaymentIntentId                   String    @unique
  purchaserUserId                         String?
  purchaserEmail                          String
  recipientEmail                          String
  recipientName                           String?
  giftMessage                             String?
  claimTokenHash                          String?   @unique
  claimedByUserId                         String?
  claimedAt                               DateTime?
  emailSentAt                             DateTime?
  createdAt                               DateTime  @default(now())
  expiresAt                               DateTime?
  status                                  String    @default("pending")
  User_GiftPurchase_claimedByUserIdToUser User?     @relation("GiftPurchase_claimedByUserIdToUser", fields: [claimedByUserId], references: [id])
  User_GiftPurchase_purchaserUserIdToUser User?     @relation("GiftPurchase_purchaserUserIdToUser", fields: [purchaserUserId], references: [id])

  @@index([purchaserUserId])
  @@index([recipientEmail])
  @@index([status])
}

model InfluencerClick {
  id        String   @id
  creator   String
  clickedAt DateTime @default(now())

  @@index([clickedAt])
  @@index([creator])
}

model LearnerProfile {
  id           String         @id
  userId       String
  displayName  String
  avatar       String?
  isDefault    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  partProgress PartProgress[]
  studySessions StudySession[]

  @@index([userId])
}

model PartProgress {
  id                 String         @id
  userId             String
  partNumber         Int
  status             String         @default("not_started")
  lastAccessedAt     DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime
  briefingOpened     Boolean        @default(false)
  flashcardsReviewed Boolean        @default(false)
  masteredAt         DateTime?
  openedAssets       String         @default("[]")
  quizAttempts       Int            @default(0)
  quizBestScore      Int?
  quizCompleted      Boolean        @default(false)
  quizPassed         Boolean        @default(false)
  quizScore          Int?
  videoCompleted     Boolean        @default(false)
  videoWatchPercent  Int            @default(0)
  learnerProfileId   String
  learnerProfile     LearnerProfile @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([learnerProfileId, partNumber])
  @@index([learnerProfileId])
  @@index([status])
  @@index([userId])
}

model Purchase {
  id                    String   @id
  userId                String
  planId                String
  planName              String
  amount                Int
  currency              String   @default("usd")
  status                String   @default("pending")
  stripePaymentIntentId String   @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  creator               String?
  promoCode             String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([creator])
  @@index([promoCode])
  @@index([status])
  @@index([userId])
}

model Quiz {
  id               String         @id
  seerahPartId     String?
  classId          String?
  title            String
  description      String?
  quizType         String         @default("part_quiz")
  passingScore     Int            @default(70)
  maxAttempts      Int?
  timeLimitMinutes Int?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  Class            Class?         @relation(fields: [classId], references: [id], onDelete: Cascade)
  SeerahPart       SeerahPart?    @relation(fields: [seerahPartId], references: [id])
  QuizAttempt      QuizAttempt[]
  QuizQuestion     QuizQuestion[]

  @@index([classId])
  @@index([seerahPartId])
}

model QuizAnswer {
  id               String       @id
  quizAttemptId    String
  questionId       String
  selectedOptionId String?
  answerText       String?
  isCorrect        Boolean?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime
  QuizQuestion     QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  QuizAttempt      QuizAttempt  @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  QuizOption       QuizOption?  @relation(fields: [selectedOptionId], references: [id])

  @@index([quizAttemptId])
}

model QuizAttempt {
  id             String         @id
  quizId         String
  classId        String?
  studentId      String
  startedAt      DateTime       @default(now())
  submittedAt    DateTime?
  score          Int?
  passed         Boolean?
  status         String         @default("in_progress")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  QuizAnswer     QuizAnswer[]
  Class          Class?         @relation(fields: [classId], references: [id])
  Quiz           Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([studentId])
}

model QuizOption {
  id           String       @id
  questionId   String
  optionText   String
  isCorrect    Boolean      @default(false)
  orderIndex   Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  QuizAnswer   QuizAnswer[]
  QuizQuestion QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizQuestion {
  id           String       @id
  quizId       String
  questionText String
  questionType String       @default("multiple_choice")
  explanation  String?
  orderIndex   Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  QuizAnswer   QuizAnswer[]
  QuizOption   QuizOption[]
  Quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model ReleaseRule {
  id                     String                   @id
  classId                String
  classCourseItemId      String?
  targetType             String
  targetId               String?
  releaseMode            String
  scheduledAt            DateTime?
  conditionType          String?
  conditionValue         String?
  isReleased             Boolean                  @default(false)
  releasedAt             DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  ClassCourseItem        ClassCourseItem?         @relation(fields: [classCourseItemId], references: [id])
  Class                  Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  StudentReleaseOverride StudentReleaseOverride[]

  @@index([classId])
  @@index([isReleased])
  @@index([targetType])
}

model SeerahPart {
  id                   String               @id
  partNumber           Int                  @unique
  title                String
  slug                 String               @unique
  subtitle             String?
  era                  String
  shortDescription     String?
  longDescription      String?
  orderIndex           Int
  durationMinutes      Int?
  includedInEssentials Boolean              @default(false)
  isPublished          Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime
  ClassCourseItem      ClassCourseItem[]
  CourseTemplateItem   CourseTemplateItem[]
  ExamPartLink         ExamPartLink[]
  Quiz                 Quiz[]
  SeerahPartAsset      SeerahPartAsset[]

  @@index([era])
  @@index([orderIndex])
}

model SeerahPartAsset {
  id           String     @id
  seerahPartId String
  assetType    String
  title        String?
  url          String?
  filePath     String?
  assetOrder   Int        @default(0)
  metadataJson String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  SeerahPart   SeerahPart @relation(fields: [seerahPartId], references: [id], onDelete: Cascade)

  @@index([assetType])
  @@index([seerahPartId])
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model StudentProfile {
  id                     String                   @id
  userId                 String                   @unique
  dateOfBirth            DateTime?
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  ClassEnrollment        ClassEnrollment[]
  ExamAttempt            ExamAttempt[]
  QuizAttempt            QuizAttempt[]
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  StudentProgress        StudentProgress[]
  StudentReleaseOverride StudentReleaseOverride[]
}

model StudentProgress {
  id                   String          @id
  classId              String
  studentId            String
  classCourseItemId    String
  status               String          @default("locked")
  startedAt            DateTime?
  completedAt          DateTime?
  lastAccessedAt       DateTime?
  completionPercentage Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime
  ClassCourseItem      ClassCourseItem @relation(fields: [classCourseItemId], references: [id], onDelete: Cascade)
  Class                Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  StudentProfile       StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classCourseItemId])
  @@index([classId])
  @@index([status])
}

model StudentReleaseOverride {
  id             String         @id
  releaseRuleId  String
  studentId      String
  isVisible      Boolean        @default(true)
  isUnlocked     Boolean        @default(false)
  availableFrom  DateTime?
  availableUntil DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  ReleaseRule    ReleaseRule    @relation(fields: [releaseRuleId], references: [id], onDelete: Cascade)
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([releaseRuleId, studentId])
  @@index([studentId])
}

model StudySession {
  id               String          @id
  userId           String
  partNumber       Int
  secondsTracked   Int             @default(0)
  startedAt        DateTime        @default(now())
  lastUpdatedAt    DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  learnerProfileId String?
  learnerProfile   LearnerProfile? @relation(fields: [learnerProfileId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([learnerProfileId])
  @@index([partNumber])
  @@index([startedAt])
  @@index([userId])
}

model Subscription {
  id                   String   @id
  userId               String
  stripeCustomerId     String
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model SupportTicket {
  id        String   @id
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

model User {
  id                                              String           @id
  fullName                                        String
  email                                           String           @unique
  passwordHash                                    String?
  role                                            String
  emailVerified                                   Boolean          @default(false)
  verificationToken                               String?          @unique
  passwordResetToken                              String?          @unique
  passwordResetExpiry                             DateTime?
  lastLoginAt                                     DateTime?
  isActive                                        Boolean          @default(true)
  profileImage                                    String?
  timezone                                        String           @default("UTC")
  createdAt                                       DateTime         @default(now())
  updatedAt                                       DateTime
  hasPaid                                         Boolean          @default(false)
  stripePaymentIntentId                           String?
  verificationExpires                             DateTime?
  courseFor                                       String           @default("myself")
  parentEmail                                     String?
  sendWeeklyReports                               Boolean          @default(false)
  studentName                                     String?
  parentEmailVerified                             Boolean          @default(false)
  parentVerificationToken                         String?          @unique
  stripeCustomerId                                String?          @unique
  planType                                        String           @default("individual")
  ActivityLog                                     ActivityLog[]
  GiftPurchase_GiftPurchase_claimedByUserIdToUser GiftPurchase[]   @relation("GiftPurchase_claimedByUserIdToUser")
  GiftPurchase_GiftPurchase_purchaserUserIdToUser GiftPurchase[]   @relation("GiftPurchase_purchaserUserIdToUser")
  learnerProfiles                                 LearnerProfile[]
  partProgress                                    PartProgress[]
  purchases                                       Purchase[]
  sessions                                        Session[]
  studentProfile                                  StudentProfile?
  studySessions                                   StudySession[]
  subscriptions                                   Subscription[]

  @@index([email])
  @@index([passwordResetToken])
  @@index([role])
  @@index([verificationToken])
}
